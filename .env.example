# Forge environment variables
#
# Copy this file to `.env` and fill in the values you want
# to use, then `source` it from your shell:
#
#   cp .env.example .env
#   vim .env        # edit
#   source .env
#
# Or set the values directly in your shell profile.
#
# SECURITY
# --------
# Do NOT commit a real API key to this file or to the
# repository. The NIM key rotation is your responsibility —
# see README.md for the security callout.
# ---------------------------------------------------------------------------

# NVIDIA NIM API key. Used by the default OpenAI-compatible
# adapter against https://integrate.api.nvidia.com/v1.
# Rotate this in the NIM console if you ever paste it in
# chat / commit it / leak it.
NVIDIA_API_KEY=

# Generic fallback for any OpenAI-compatible endpoint. Only
# used if NVIDIA_API_KEY is unset.
OPENAI_API_KEY=

# Highest-precedence override; wins over the two above. Use
# for the rotated key while you're transitioning off a leaked
# one.
FORGE_API_KEY=

# API base URL override. Defaults to the NIM endpoint. Set
# this to point Forge at OpenAI, Azure OpenAI, LM Studio, or
# any other OpenAI-compatible chat-completions server.
# Examples:
#   https://api.openai.com/v1
#   http://localhost:1234/v1
# FORGE_API_BASE=https://integrate.api.nvidia.com/v1

# Default model id. Defaults to the NIM Llama 3.3 70B model.
# FORGE_MODEL=meta/llama-3.3-70b-instruct

# Enable debug logging. Any non-empty value flips the slog
# level to DEBUG.
# FORGE_DEBUG=1

# Override the working directory Forge runs in.
# FORGE_CWD=
